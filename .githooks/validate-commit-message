#!/usr/bin/env bash

set -euo pipefail

message="${1:-}"

if [[ -z "$message" ]]; then
  echo "Commit message cannot be empty." >&2
  exit 1
fi

# Allow subjects generated by standard Git workflows.
if [[ "$message" =~ ^Merge\  ]] ||
   [[ "$message" =~ ^Revert\ \" ]] ||
   [[ "$message" =~ ^fixup!\  ]] ||
   [[ "$message" =~ ^squash!\  ]]; then
  exit 0
fi

if (( ${#message} > 72 )); then
  echo "Commit subject must be 72 characters or fewer (${#message} found)." >&2
  exit 1
fi

pattern='^(feat|fix|docs|test|refactor|style|perf|build|ci|chore|revert)(\([a-z0-9][a-z0-9._/-]*\))?!?: .+'

if [[ ! "$message" =~ $pattern ]]; then
  cat >&2 <<'EOF'
Invalid commit message.

Expected:
  <type>(optional-scope): <description>

Examples:
  feat(auth): add login validation
  fix(docker): preserve frontend dependencies
  docs(readme): document project setup

Allowed types:
  feat, fix, docs, test, refactor, style, perf, build, ci, chore, revert
EOF
  exit 1
fi

if [[ "$message" == *. ]]; then
  echo "Commit subject must not end with a period." >&2
  exit 1
fi
